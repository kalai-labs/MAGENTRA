{
  "name": "magentra",
  "version": "0.5.2.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": [
    "engine/*",
    "app"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "app": "npm start --workspace app",
    "dist:linux": "npm run dist:linux --workspace app",
    "dist:win": "npm run dist --workspace app",
    "dist:mac": "npm run dist:mac --workspace app",
    "prepare": "git config core.hooksPath .githooks || true",
    "commit": "node tools/version/bin/magentra-version.mjs commit",
    "version:current": "node tools/version/bin/magentra-version.mjs current",
    "version:plan": "node tools/version/bin/magentra-version.mjs plan",
    "version:apply": "node tools/version/bin/magentra-version.mjs apply",
    "version:check": "node tools/version/bin/magentra-version.mjs check",
    "test:version": "node tools/version/bin/run-tests.mjs",
    "test:ui": "npm run test:main --workspace app && npm run test:ui --workspace app",
    "typecheck:version": "tsc -p tools/version",
    "fetch:rg-win": "npm install --no-save --force --os=win32 --cpu=x64 @vscode/ripgrep-win32-x64"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "@vscode/ripgrep-win32-x64": "^1.18.0"
  }
}
