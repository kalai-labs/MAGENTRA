{
  "name": "magentra-app",
  "version": "0.2.2.0",
  "private": true,
  "description": "MAGENTRA desktop app — the Electron shell around the agent engine.",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/launch.js",
    "bundle:engine": "node scripts/bundle-engine.js",
    "dist": "node scripts/bundle-engine.js --target win && node scripts/dist.js --win portable",
    "dist:linux": "node scripts/bundle-engine.js --target linux && node scripts/dist.js --linux",
    "dist:mac": "node scripts/bundle-engine.js --target mac && node scripts/dist.js --mac",
    "dist:all": "node scripts/bundle-engine.js --target win --target linux && node scripts/dist.js --win portable --linux",
    "smoke": "node scripts/launch.js --smoke"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "com.magentra.app",
    "productName": "MAGENTRA",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "scripts/afterPack.js",
    "files": [
      "package.json",
      {
        "from": "build-resources/app",
        "to": "."
      }
    ],
    "win": {
      "target": "portable",
      "artifactName": "MAGENTRA-${env.MAGENTRA_VERSION}-win-portable.exe",
      "signExecutable": false,
      "extraResources": [
        {
          "from": "build-resources/engine",
          "to": "engine",
          "filter": [
            "engine.cjs",
            "rg.exe"
          ]
        }
      ]
    },
    "linux": {
      "executableName": "magentra",
      "syncDesktopName": true,
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MAGENTRA-${env.MAGENTRA_VERSION}-linux-${arch}.${ext}",
      "category": "Development",
      "extraResources": [
        {
          "from": "build-resources/engine",
          "to": "engine",
          "filter": [
            "engine.cjs",
            "rg"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "MAGENTRA-${env.MAGENTRA_VERSION}-mac-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "extraResources": [
        {
          "from": "build-resources/engine",
          "to": "engine",
          "filter": [
            "engine.cjs",
            "rg"
          ]
        }
      ]
    }
  }
}
