{
  "name": "magentra-app",
  "version": "0.1.0.0",
  "private": true,
  "description": "MAGENTRA desktop app — the Electron shell around the agent engine.",
  "homepage": "https://github.com/kalai-labs/MAGENTRA",
  "author": "Kalai Labs <muhammetaliozturk.ofis@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/launch.js",
    "bundle:engine": "node scripts/bundle-engine.js",
    "dist": "node scripts/bundle-engine.js --target win && node scripts/dist.js --win",
    "dist:linux": "node scripts/bundle-engine.js --target linux && node scripts/dist.js --linux",
    "dist:mac": "node scripts/bundle-engine.js --target mac && node scripts/dist.js --mac",
    "dist:all": "node scripts/bundle-engine.js --target win --target linux && node scripts/dist.js --win --linux",
    "smoke": "node scripts/launch.js --smoke",
    "test:ui": "node tests/run-ui-tests.js",
    "test:main": "node tests/changes.test.js && node tests/window.test.js && node tests/connection.test.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "com.magentra.app",
    "productName": "MAGENTRA",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "scripts/afterPack.js",
    "files": [
      "package.json",
      {
        "from": "build-resources/app",
        "to": "."
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "signExecutable": false,
      "extraResources": [
        {
          "from": "build-resources/engine",
          "to": "engine",
          "filter": [
            "engine.cjs",
            "rg.exe"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "MAGENTRA-${env.MAGENTRA_VERSION}-win-portable.exe"
    },
    "nsis": {
      "artifactName": "MAGENTRA-${env.MAGENTRA_VERSION}-win-setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "executableName": "magentra",
      "syncDesktopName": true,
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MAGENTRA-${env.MAGENTRA_VERSION}-linux-${arch}.${ext}",
      "category": "Development",
      "extraResources": [
        {
          "from": "build-resources/engine",
          "to": "engine",
          "filter": [
            "engine.cjs",
            "rg"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "MAGENTRA-${env.MAGENTRA_VERSION}-mac-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "extraResources": [
        {
          "from": "build-resources/engine",
          "to": "engine",
          "filter": [
            "engine.cjs",
            "rg"
          ]
        }
      ]
    }
  }
}
