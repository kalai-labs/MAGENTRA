#!/bin/sh
#
# Check the commit message before git accepts it.
#
# Git calls this hook. `npm install` turns it on with `core.hooksPath`.
# To turn it off for one commit, use `git commit --no-verify`.

exec node "$(git rev-parse --show-toplevel)/tools/version/bin/magentra-version.mjs" \
  check --message-file "$1"
